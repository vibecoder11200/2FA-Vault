########################################################################
#                                                                      #
#                  2FA-VAULT ENVIRONMENT VARIABLES                     #
#                                                                      #
#  This is a template file. Copy it to .env and configure values.     #
#  NEVER commit .env to version control - it contains secrets!        #
#                                                                      #
########################################################################

# ┌─────────────────────────────────────────────────────────────────┐
# │                        APPLICATION SETTINGS                      │
# └─────────────────────────────────────────────────────────────────┘

# Application name (displayed in UI, emails, PWA)
APP_NAME="2FA-Vault"

# Environment: local, production, testing
# Use "production" for live deployments
APP_ENV=local

# Enable debug mode (set to false in production!)
APP_DEBUG=false

# Application timezone (affects timestamps in DB)
# List: https://www.php.net/manual/en/timezones.php
APP_TIMEZONE=UTC

# Site owner email (for system notifications)
SITE_OWNER=admin@example.com

# Application URL (must match your domain for WebAuthn to work)
# Examples:
#   http://localhost:8000 (development)
#   https://vault.example.com (production)
APP_URL=http://localhost

# Subdirectory if serving from non-root path
# Example: APP_URL=https://example.com/2fa → APP_SUBDIRECTORY=2fa
# Leave empty for root domain
APP_SUBDIRECTORY=

# Demo mode (resets data every hour, creates demo user)
IS_DEMO_APP=false

# Port for the application (Docker)
APP_PORT=8000

# ┌─────────────────────────────────────────────────────────────────┐
# │                       ENCRYPTION SETTINGS                        │
# └─────────────────────────────────────────────────────────────────┘

# Laravel application key (32 chars)
# Generate with: php artisan key:generate
# IMPORTANT: Keep this secret! Changing it invalidates sessions.
APP_KEY=

# Previous encryption keys (comma-separated, for key rotation)
# Used to decrypt data encrypted with old keys
# APP_PREVIOUS_KEYS=OldKey1,OldKey2

# Zero-knowledge E2EE encryption (ALWAYS TRUE in 2FA-Vault)
ENCRYPTION_ENABLED=true

# Argon2id parameters (for master password hashing)
# Memory cost in KB (default: 64 MB = 65536 KB)
# Higher = more secure, but slower
ARGON2_MEMORY=65536

# Time cost (iterations, default: 3)
# Higher = more secure, but slower
ARGON2_TIME=3

# Parallelism (threads, default: 4)
# Match your server's CPU cores
ARGON2_THREADS=4

# ┌─────────────────────────────────────────────────────────────────┐
# │                        DATABASE SETTINGS                         │
# └─────────────────────────────────────────────────────────────────┘

# Database driver: mysql, pgsql, sqlsrv, sqlite
DB_CONNECTION=mysql

# Database name
DB_DATABASE=2fa_vault

# Database host (use service name in Docker)
DB_HOST=mysql

# Database port
DB_PORT=3306

# Database credentials
DB_USERNAME=2fa_vault_user
DB_PASSWORD=

# Root password (for initial setup)
DB_ROOT_PASSWORD=

# MySQL SSL CA bundle (absolute path)
# MYSQL_ATTR_SSL_CA=/path/to/ca-bundle.crt

# ┌─────────────────────────────────────────────────────────────────┐
# │                         REDIS SETTINGS                           │
# └─────────────────────────────────────────────────────────────────┘

# Redis host (use service name in Docker)
REDIS_HOST=redis

# Redis port
REDIS_PORT=6379

# Redis password (generate with: openssl rand -base64 32)
REDIS_PASSWORD=

# Redis client (phpredis recommended for performance)
REDIS_CLIENT=phpredis

# Redis database numbers (0-15, use different DBs for different purposes)
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

# ┌─────────────────────────────────────────────────────────────────┐
# │                    CACHE & SESSION SETTINGS                      │
# └─────────────────────────────────────────────────────────────────┘

# Cache driver: file, redis, memcached
# Use redis in production for better performance
CACHE_DRIVER=redis

# Session driver: file, redis, cookie
# Use redis in production for multi-server deployments
SESSION_DRIVER=redis

# Session lifetime in minutes
SESSION_LIFETIME=120

# Queue connection: sync, redis, database
# Use redis in production for background jobs
QUEUE_CONNECTION=redis

# ┌─────────────────────────────────────────────────────────────────┐
# │                      MULTI-USER SETTINGS                         │
# └─────────────────────────────────────────────────────────────────┘

# Allow new user registration
# Set to false to disable public signups (invite-only)
ALLOW_REGISTRATION=false

# Maximum teams a user can join/own
MAX_TEAMS_PER_USER=5

# Default team name for new users
DEFAULT_TEAM_NAME="Personal"

# ┌─────────────────────────────────────────────────────────────────┐
# │                       MAIL SETTINGS                              │
# └─────────────────────────────────────────────────────────────────┘

# Mail driver: smtp, sendmail, mailgun, ses, log
MAIL_MAILER=smtp

# SMTP host
MAIL_HOST=smtp.mailtrap.io

# SMTP port (25, 465, 587, 2525)
MAIL_PORT=2525

# SMTP credentials
MAIL_USERNAME=
MAIL_PASSWORD=

# Encryption: tls, ssl, null
MAIL_ENCRYPTION=tls

# From address (must be valid for your SMTP server)
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Verify SSL peer (set false only for testing)
MAIL_VERIFY_SSL_PEER=true

# ┌─────────────────────────────────────────────────────────────────┐
# │                   WEB PUSH NOTIFICATIONS                         │
# └─────────────────────────────────────────────────────────────────┘

# VAPID keys (generate with: npm install -g web-push && web-push generate-vapid-keys)
# Public key (safe to expose to clients)
VAPID_PUBLIC_KEY=

# Private key (KEEP SECRET!)
VAPID_PRIVATE_KEY=

# Subject (mailto: or https: URL identifying your app)
VAPID_SUBJECT=mailto:admin@example.com

# ┌─────────────────────────────────────────────────────────────────┐
# │                       PWA SETTINGS                               │
# └─────────────────────────────────────────────────────────────────┘

# PWA display name (shown when installed)
PWA_NAME="2FA-Vault"

# PWA short name (shown on home screen)
PWA_SHORT_NAME="2FA-Vault"

# PWA theme color (hex color for address bar)
PWA_THEME_COLOR="#4F46E5"

# PWA background color (hex color for splash screen)
PWA_BACKGROUND_COLOR="#FFFFFF"

# ┌─────────────────────────────────────────────────────────────────┐
# │                      LOGGING SETTINGS                            │
# └─────────────────────────────────────────────────────────────────┘

# Log channel: daily, errorlog, syslog, stderr, stack
# daily = 7 rotated log files in storage/logs/
LOG_CHANNEL=daily

# Log level: debug, info, notice, warning, error, critical, alert, emergency
# Use "info" in production, "debug" only for troubleshooting
LOG_LEVEL=info

# ┌─────────────────────────────────────────────────────────────────┐
# │                      RATE LIMITING                               │
# └─────────────────────────────────────────────────────────────────┘

# API rate limit (requests per minute from same IP)
# Format: max_attempts,decay_minutes
# Example: 60,1 = 60 requests per minute
# Set to null to disable
THROTTLE_API=60,1

# Login rate limit (attempts per minute from same IP)
# Format: max_attempts,decay_minutes
# Example: 5,1 = 5 login attempts per minute
THROTTLE_LOGIN=5,1

# Import API rate limit (higher than normal API)
# Set to null to disable (inherits THROTTLE_API)
THROTTLE_API_DURING_IMPORT=1000,1

# ┌─────────────────────────────────────────────────────────────────┐
# │                   AUTHENTICATION SETTINGS                        │
# └─────────────────────────────────────────────────────────────────┘

# Authentication guard: web-guard, reverse-proxy-guard
# web-guard = built-in Laravel auth (default)
# reverse-proxy-guard = trust reverse proxy headers (advanced)
AUTHENTICATION_GUARD=web-guard

# Authentication log retention (days)
# Logs older than this are auto-deleted
AUTHENTICATION_LOG_RETENTION=365

# Reverse proxy headers (only if using reverse-proxy-guard)
# AUTH_PROXY_HEADER_FOR_USER=REMOTE_USER
# AUTH_PROXY_HEADER_FOR_EMAIL=REMOTE_EMAIL

# Custom logout URL (for auth proxies)
# PROXY_LOGOUT_URL=https://auth.example.com/logout

# ┌─────────────────────────────────────────────────────────────────┐
# │                      WEBAUTHN SETTINGS                           │
# └─────────────────────────────────────────────────────────────────┘

# WebAuthn Relying Party name (defaults to APP_NAME)
WEBAUTHN_NAME="${APP_NAME}"

# WebAuthn Relying Party ID (should match domain, e.g., vault.example.com)
# Set to null to auto-detect (recommended)
WEBAUTHN_ID=null

# User verification: required, preferred, discouraged
# required = always ask for biometric/PIN
# preferred = ask if available (default)
# discouraged = never ask
WEBAUTHN_USER_VERIFICATION=preferred

# ┌─────────────────────────────────────────────────────────────────┐
# │                      SECURITY SETTINGS                           │
# └─────────────────────────────────────────────────────────────────┘

# Content Security Policy (prevents XSS)
# Set to true in production
CONTENT_SECURITY_POLICY=true

# Block fetching images from OTPAuth URIs (prevents SSRF)
# Set to true in production
BLOCK_OPTAUTH_IMAGELINK_FETCHING=true

# Trusted proxies (for HTTPS detection behind reverse proxy)
# Options:
#   * = trust all proxies (use with caution!)
#   Comma-separated IPs: 192.168.1.1,10.0.0.1
#   null = trust none
TRUSTED_PROXIES=null

# Force HTTPS (redirect HTTP to HTTPS)
FORCE_HTTPS=false

# Proxy for outgoing requests (logo fetching, version checks)
# Format: http://username:password@host:port
# PROXY_FOR_OUTGOING_REQUESTS=http://proxy.example.com:8080

# ┌─────────────────────────────────────────────────────────────────┐
# │                       SSO SETTINGS                               │
# └─────────────────────────────────────────────────────────────────┘

# OpenID Connect (OIDC) settings
# OPENID_AUTHORIZE_URL=https://auth.example.com/authorize
# OPENID_TOKEN_URL=https://auth.example.com/token
# OPENID_USERINFO_URL=https://auth.example.com/userinfo
# OPENID_CLIENT_ID=
# OPENID_CLIENT_SECRET=
# OPENID_HTTP_VERIFY_SSL_PEER=true

# GitHub OAuth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ┌─────────────────────────────────────────────────────────────────┐
# │                    USER PREFERENCE DEFAULTS                      │
# └─────────────────────────────────────────────────────────────────┘

# You can enforce and/or lock user preferences using these variables
# Format: USERPREF_DEFAULT__<PREFERENCE>=<value>
#         USERPREF_LOCKED__<PREFERENCE>=true

# Example: Force light theme for all users
# USERPREF_DEFAULT__THEME=light
# USERPREF_LOCKED__THEME=true

# Example: Default language to French
# USERPREF_DEFAULT__LANG=fr

# ┌─────────────────────────────────────────────────────────────────┐
# │                  ADVANCED / DO NOT MODIFY                        │
# └─────────────────────────────────────────────────────────────────┘

# Broadcasting driver (for real-time features)
BROADCAST_DRIVER=log

# Pusher settings (if using Pusher for broadcasting)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Mix environment (for asset compilation)
MIX_ENV=local

# ┌─────────────────────────────────────────────────────────────────┐
# │                      QUICK START GUIDE                           │
# └─────────────────────────────────────────────────────────────────┘

# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Generate APP_KEY:
#    php artisan key:generate
#
# 3. Generate VAPID keys:
#    npm install -g web-push
#    web-push generate-vapid-keys --json
#
# 4. Set strong passwords:
#    DB_PASSWORD (openssl rand -base64 32)
#    DB_ROOT_PASSWORD (openssl rand -base64 32)
#    REDIS_PASSWORD (openssl rand -base64 32)
#
# 5. Configure your domain:
#    APP_URL=https://vault.example.com
#
# 6. Set up mail (use Mailtrap for testing):
#    MAIL_HOST=smtp.mailtrap.io
#    MAIL_PORT=2525
#    MAIL_USERNAME=<your-username>
#    MAIL_PASSWORD=<your-password>
#
# 7. Start the app:
#    docker-compose -f docker-compose.prod.yml up -d
#
# 8. Run migrations:
#    docker-compose exec app php artisan migrate --force
#
# 9. Visit APP_URL and register your first user!
#
# Documentation: https://docs.2fa-vault.example.com
# Security: security@2fa-vault.example.com
