########################################################################
#                                                                      #
#            2FA-VAULT DEVELOPMENT ENVIRONMENT VARIABLES               #
#                                                                      #
########################################################################

# ┌─────────────────────────────────────────────────────────────────┐
# │                        APPLICATION SETTINGS                      │
# └─────────────────────────────────────────────────────────────────┘

APP_NAME="2FA-Vault-Dev"
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
APP_SUBDIRECTORY=

# Generate with: php artisan key:generate
APP_KEY=base64:5mXva9j/GNGOgeXSAkJdp8AhBPDSiNhYiy24tJZyzrw=

# Demo mode (useful for testing)
IS_DEMO_APP=false

# ┌─────────────────────────────────────────────────────────────────┐
# │                       DATABASE SETTINGS                          │
# └─────────────────────────────────────────────────────────────────┘

# SQLite (default for dev - simple and fast)
DB_CONNECTION=sqlite
DB_DATABASE=/srv/database/database.sqlite

# Uncomment to use MySQL instead
# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=2fa_vault_dev
# DB_USERNAME=2fa_vault
# DB_PASSWORD=secret

# ┌─────────────────────────────────────────────────────────────────┐
# │                    CACHE & SESSION SETTINGS                      │
# └─────────────────────────────────────────────────────────────────┘

# File-based for dev (no Redis dependency)
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Sync queue (no background jobs in dev)
QUEUE_CONNECTION=sync

# Uncomment to use Redis
# CACHE_DRIVER=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_CLIENT=phpredis
# REDIS_CACHE_DB=1
# REDIS_SESSION_DB=2
# REDIS_QUEUE_DB=3

# ┌─────────────────────────────────────────────────────────────────┐
# │                       ENCRYPTION SETTINGS                        │
# └─────────────────────────────────────────────────────────────────┘

# Disabled for easier testing (enable to test E2EE features)
ENCRYPTION_ENABLED=false

# Argon2id parameters (lighter for dev)
ARGON2_MEMORY=32768    # 32 MB (vs 64 MB in prod)
ARGON2_TIME=2          # 2 iterations (vs 3 in prod)
ARGON2_THREADS=2       # 2 threads (vs 4 in prod)

# ┌─────────────────────────────────────────────────────────────────┐
# │                      MULTI-USER SETTINGS                         │
# └─────────────────────────────────────────────────────────────────┘

# Allow registration for testing
ALLOW_REGISTRATION=true

# Higher limits for dev
MAX_TEAMS_PER_USER=10
DEFAULT_TEAM_NAME="Personal"

# ┌─────────────────────────────────────────────────────────────────┐
# │                       MAIL SETTINGS                              │
# └─────────────────────────────────────────────────────────────────┘

# Log to file (no actual emails sent)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=dev@2fa-vault.local
MAIL_FROM_NAME="2FA-Vault Dev"

# Uncomment to use MailHog for testing emails
# MAIL_MAILER=smtp
# MAIL_HOST=mailhog
# MAIL_PORT=1025
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_ENCRYPTION=null

# ┌─────────────────────────────────────────────────────────────────┐
# │                   WEB PUSH NOTIFICATIONS                         │
# └─────────────────────────────────────────────────────────────────┘

# Generate with: npm install -g web-push && web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@2fa-vault.local

# ┌─────────────────────────────────────────────────────────────────┐
# │                       PWA SETTINGS                               │
# └─────────────────────────────────────────────────────────────────┘

PWA_NAME="2FA-Vault Dev"
PWA_SHORT_NAME="2FA-Dev"
PWA_THEME_COLOR="#4F46E5"
PWA_BACKGROUND_COLOR="#FFFFFF"

# ┌─────────────────────────────────────────────────────────────────┐
# │                      LOGGING SETTINGS                            │
# └─────────────────────────────────────────────────────────────────┘

# Debug level for development
LOG_CHANNEL=daily
LOG_LEVEL=debug

# ┌─────────────────────────────────────────────────────────────────┐
# │                      RATE LIMITING                               │
# └─────────────────────────────────────────────────────────────────┘

# Relaxed limits for dev
THROTTLE_API=1000,1
THROTTLE_LOGIN=100,1
THROTTLE_API_DURING_IMPORT=null

# ┌─────────────────────────────────────────────────────────────────┐
# │                   AUTHENTICATION SETTINGS                        │
# └─────────────────────────────────────────────────────────────────┘

AUTHENTICATION_GUARD=web-guard
AUTHENTICATION_LOG_RETENTION=365

# ┌─────────────────────────────────────────────────────────────────┐
# │                      WEBAUTHN SETTINGS                           │
# └─────────────────────────────────────────────────────────────────┘

WEBAUTHN_NAME="2FA-Vault Dev"
WEBAUTHN_ID=localhost
WEBAUTHN_USER_VERIFICATION=preferred

# ┌─────────────────────────────────────────────────────────────────┐
# │                      SECURITY SETTINGS                           │
# └─────────────────────────────────────────────────────────────────┘

# Relaxed for dev (enable for testing security features)
CONTENT_SECURITY_POLICY=false
BLOCK_OPTAUTH_IMAGELINK_FETCHING=false
TRUSTED_PROXIES=*
FORCE_HTTPS=false

# ┌─────────────────────────────────────────────────────────────────┐
# │                       VITE SETTINGS                              │
# └─────────────────────────────────────────────────────────────────┘

VITE_DEV_SERVER_URL=http://localhost:5173
