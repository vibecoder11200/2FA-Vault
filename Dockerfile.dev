FROM php:8.4-cli-alpine

ARG UID=1000
ARG GID=1000

# Install system dependencies and PHP extensions
RUN apk add --no-cache \
    # Build tools
    git \
    curl \
    unzip \
    nodejs \
    npm \
    # PHP extensions dependencies
    libpng-dev \
    libjpeg-turbo-dev \
    freetype-dev \
    libzip-dev \
    oniguruma-dev \
    icu-dev \
    postgresql-dev \
    sqlite-dev \
    libxml2-dev \
    libxslt-dev \
    # Playwright / Chromium runtime dependencies
    nss \
    nspr \
    dbus-libs \
    cups-libs \
    libatk-1.0 \
    libatk-bridge-2.0 \
    at-spi2-core \
    glib \
    libdrm \
    mesa \
    libxkbcommon \
    pango \
    cairo \
    alsa-lib \
    libgcc \
    libstdc++ \
    expat \
    fontconfig \
    ttf-freefont \
    ca-certificates \
    libc6-compat \
    udev \
    xvfb-run \
    xdg-utils \
    xauth \
    tzdata \
    freetype \
    harfbuzz \
    jpeg \
    zlib \
    libcap \
    libxcomposite \
    libxdamage \
    libxfixes \
    libxrandr \
    libxrender \
    libxext \
    libxi \
    libxcursor \
    libx11 \
    libxcb \
    libxau \
    libxdmcp \
    libxshmfence \
    libxxf86vm \
    eudev-libs \
    mesa-egl \
    mesa-gl \
    mesa-gles \
    mesa-vulkan-swrast \
    # Additional build dependencies
    autoconf \
    g++ \
    make \
    # Tools
    bash \
    vim

# Configure and install PHP extensions
RUN docker-php-ext-configure gd --with-freetype --with-jpeg && \
    docker-php-ext-install -j$(nproc) \
        gd \
        bcmath \
        pdo \
        pdo_mysql \
        pdo_pgsql \
        pdo_sqlite \
        mbstring \
        xml \
        ctype \
        fileinfo \
        zip \
        intl

# Install Composer
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# Set working directory
WORKDIR /srv

# Configure git to allow operations in any directory (for development)
RUN git config --global --add safe.directory '*'

# Allow Composer to run as root in dev environment
ENV COMPOSER_ALLOW_SUPERUSER=1

# Expose ports
EXPOSE 8000 5173

# Keep container running
CMD ["sh"]
